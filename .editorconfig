root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

# Fixtures are byte-exact test data; editors must not "fix" them.
[tests/fixtures/**]
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
