{
  "schemaVersion": "1.0.0",
  "protocolVersion": "1.0.0",
  "id": "example-exporter",
  "version": "1.0.0",
  "displayName": "example-exporter",
  "description": "Candidate export files produced by the example-exporter exporter extension.",
  "kind": "exporter",
  "entrypoint": "dist/extension.cjs",
  "compatibility": {
    "specbridge": ">=0.7.1 <2.0.0",
    "extensionSdk": ">=0.7.1 <2.0.0"
  },
  "capabilities": {
    "operations": [
      "exporter.export"
    ]
  },
  "permissions": {
    "specRead": true,
    "repositoryRead": false,
    "repositoryWrite": false,
    "network": false,
    "childProcess": false,
    "environmentVariables": []
  },
  "license": "MIT",
  "keywords": [
    "exporter",
    "specbridge-extension"
  ]
}
