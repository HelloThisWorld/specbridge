{
  "name": "specbridge-monorepo",
  "version": "0.3.0",
  "private": true,
  "description": "An open, model-agnostic spec runtime for existing Kiro projects.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "clean": "pnpm -r clean",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "node scripts/smoke.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/node": "^20.17.0",
    "eslint": "^9.14.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.14.0",
    "vitest": "^3.0.0"
  }
}
